# ── Database ─────────────────────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/change_review
# SQLite (local dev fallback — no setup needed)
# DATABASE_URL=sqlite:///./change_review.db

# Change Review Orchestrator — Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

APP_ENV=development
APP_LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-before-deploying-to-any-real-env

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=change_review
POSTGRES_USER=cro_user
POSTGRES_PASSWORD=cro_secret

REDIS_URL=redis://localhost:6379/0

LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3
LLM_API_KEY=ollama

ARTIFACT_STORE_PATH=./artifacts

ENABLE_LLM_AGENTS=false
ENABLE_HUMAN_IN_THE_LOOP=false

# ── Gemini LLM ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=1024
